{
  "name": "@angular-builders/timestamp",
  "version": "21.0.4-beta.10",
  "repository": {
    "type": "git",
    "url": "https://github.com/just-jeb/angular-builders",
    "directory": "packages/timestamp"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "JeB Barabanov",
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist",
    "builders.json"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "builders": "builders.json",
  "scripts": {
    "prebuild": "yarn clean && yarn generate",
    "build": "yarn prebuild && tsc && yarn postbuild",
    "postbuild": "yarn copy",
    "clean": "rimraf dist src/schema.ts",
    "copy": "cpy --flat src/schema.json dist",
    "generate": "quicktype -s schema src/schema.json -o src/schema.ts"
  },
  "dependencies": {
    "@angular-devkit/architect": ">=0.2200.0-rc.2 < 0.2300.0",
    "@angular-devkit/core": "^22.0.0-rc.2",
    "dateformat": "^5.0.0"
  },
  "devDependencies": {
    "@types/dateformat": "5.0.3",
    "@types/node": "^24.0.0",
    "cpy-cli": "^7.0.0",
    "jest": "30.4.2",
    "quicktype": "^15.0.260",
    "rimraf": "^6.0.0",
    "typescript": "6.0.3"
  }
}
