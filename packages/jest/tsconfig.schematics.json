{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/schematics",
    "rootDir": "./src/schematics",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "noImplicitAny": false,
    "types": ["node"]
  },
  "include": ["src/schematics/**/*.ts"],
  "exclude": ["src/schematics/**/*.spec.ts"]
}
